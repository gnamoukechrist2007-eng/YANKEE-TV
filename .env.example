DATABASE_URL=postgresql://iptv:CHANGE_ME@iptv-postgres:5432/iptv

# Auth.js — share with mlb-tracker for SSO across *.thorsteinson.com
AUTH_SECRET=
AUTH_URL=https://tv.thorsteinson.com
AUTH_TRUST_HOST=true
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# TV-specific allowlist (independent from mlb-tracker's ALLOWED_EMAILS)
TV_ALLOWED_EMAILS=paul.thorsteinson@gov.ab.ca

# AES-256-GCM key for IPTV credential encryption at rest
# Generate: openssl rand -hex 32
IPTV_ENC_KEY=

# Postgres (only used by iptv-postgres container)
IPTV_PG_PASSWORD=
